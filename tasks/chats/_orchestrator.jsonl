2\u043e\u0432 \u2192 \u043d\u0430\u043f\u043e\u043c\u0438\u043d\u0430\u043d\u0438\u0435 \u0437\u0430 1\u0447 \u2192 \u043e\u043f\u0440\u043e\u0441 \u043f\u043e\u0441\u043b\u0435 \u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\u0446\u0438\u0438\n- **Follow-up \u043f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c** \u2014 6 \u044d\u0442\u0430\u043f\u043e\u0432 \u043a\u0430\u043f\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u0440\u043e\u0433\u0440\u0435\u0432\u0430 (24\u0447, 3\u0434, 7\u0434...), \u043f\u0430\u0443\u0437\u0430 \u043f\u0440\u0438 \u0437\u0430\u043f\u0438\u0441\u0438\n- **\u0410\u0434\u043c\u0438\u043d\u043a\u0430** \u2014 /leads, /slots, UTM-\u0442\u0440\u0435\u043a\u0438\u043d\u0433, \u0440\u0435\u0444\u0435\u0440\u0430\u043b\u044c\u043d\u044b\u0435 \u0441\u0441\u044b\u043b\u043a\u0438, \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043f\u043e\u0434\u043f\u0438\u0441\u043a\u0438 \u043d\u0430 \u043a\u0430\u043d\u0430\u043b\n- **\u0422\u0435\u0445\u0434\u043e\u043b\u0433** \u2014 main.py \u0443\u0436\u0430\u0442 \u0441 543 \u0434\u043e 202 \u0441\u0442\u0440\u043e\u043a, \u0442\u0435\u0441\u0442\u044b \u043d\u0430 \u0432\u0441\u0435 150 \u043a\u043e\u043c\u0431\u0438\u043d\u0430\u0446\u0438\u0439, SQLite + Redis fallback\n\n**\u0412\u043e\u0440\u043e\u043d\u043a\u0430 \u0441\u043e\u0431\u0440\u0430\u043d\u0430 \u0446\u0435\u043b\u0438\u043a\u043e\u043c:** \u041a\u0430\u043d\u0430\u043b \u2192 \u041a\u0432\u0438\u0437 \u2192 \u041e\u0442\u0447\u0451\u0442 \u2192 \u0417\u0430\u043f\u0438\u0441\u044c \u2192 Drip. \u0411\u043e\u0442 \u0433\u043e\u0442\u043e\u0432 \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0442\u044c \u043b\u0438\u0434\u043e\u0432.\n\n\u0421 29 \u043c\u0430\u0440\u0442\u0430 \u2014 \u0431\u0435\u0437 \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0438. \u041d\u0443\u0436\u0435\u043d \u0442\u0440\u0430\u0444\u0438\u043a (\u0441\u0442\u0430\u0442\u044c\u0438, \u043f\u043e\u0441\u0442\u044b), \u0431\u043e\u0442 \u0441\u0432\u043e\u044e \u0447\u0430\u0441\u0442\u044c \u0434\u0435\u043b\u0430\u0435\u0442.\n\n---\n\n## \u041e\u0442\u0447\u0451\u0442 \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u0443 (ssts)\n\n\u0421\u043a\u0440\u0438\u043f\u0442 `scripts/daily-report.py` \u2014 \u043d\u0430 \u043c\u0435\u0441\u0442\u0435 \u0438 \u0440\u0430\u0431\u043e\u0447\u0438\u0439. \u041e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u0432 TG (chat_id 512723231):\n- \u0414\u043d\u0438 \u0434\u043e \u0434\u0435\u0434\u043b\u0430\u0439\u043d\u0430 + \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0441-\u0431\u0430\u0440 \u0434\u043e\u0445\u043e\u0434\u0430\n- \u041a\u043e\u043c\u043c\u0438\u0442\u044b \u0437\u0430 \u0434\u0435\u043d\u044c \u043f\u043e \u0432\u0441\u0435\u043c \u043f\u0440\u043e\u0435\u043a\u0442\u0430\u043c\n- \u0422\u0435\u043a\u0441\u0442\u043e\u0432\u043e\u0435 \u0440\u0435\u0437\u044e\u043c\u0435 \u0441\u0435\u0441\u0441\u0438\u0438\n\n\u0417\u0430\u043f\u0443\u0441\u043a: `python scripts/daily-report.py \"\u0442\u0435\u043a\u0441\u0442 \u0438\u0442\u043e\u0433\u043e\u0432 \u0434\u043d\u044f\"`. \u0425\u043e\u0447\u0435\u0448\u044c \u0447\u0442\u043e\u0431\u044b \u044f \u043e\u0442\u043f\u0440\u0430\u0432\u0438\u043b \u043e\u0442\u0447\u0451\u0442 \u0437\u0430 \u0441\u0435\u0433\u043e\u0434\u043d\u044f?"}

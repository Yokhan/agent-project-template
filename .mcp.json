{
  "mcpServers": {
    "context-router": {
      "command": "npx",
      "args": [
        "tsx",
        "mcp-servers/context-router/src/index.ts"
      ],
      "env": {}
    },
    "engram": {
      "command": "engram",
      "args": [
        "mcp"
      ]
    },
    "codesight": {
      "command": "npx",
      "args": [
        "codesight",
        "--mcp"
      ],
      "env": {},
      "disabled": true
    }
  }
}
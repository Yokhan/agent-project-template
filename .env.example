# IMPORTANT: Copy this file to .env and fill in real values.
# NEVER commit .env to git. All CHANGE_ME_BEFORE_USE values MUST be replaced.

# === Project ===
# NODE_ENV=development
# PORT=3000

# === Database ===
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# === API Keys ===
# API_KEY=CHANGE_ME_BEFORE_USE

# === Telegram Bot (optional, see integrations/telegram/) ===
# TELEGRAM_BOT_TOKEN=CHANGE_ME_BEFORE_USE
# TELEGRAM_CHAT_ID=CHANGE_ME_BEFORE_USE

# === Memory MCP (Engram — see integrations/memory-mcp/) ===
# ENGRAM_DB_PATH=~/.engram/engram.db

# === n8n Pipeline Automation (optional) ===
# N8N_URL=http://localhost:5678
# N8N_API_KEY=CHANGE_ME_BEFORE_USE
# Start n8n with: NODE_FUNCTION_ALLOW_BUILTIN=child_process,fs,path n8n start

# === Beads (optional, see integrations/beads/) ===
# BEADS_DB_PATH=.beads/beads.db

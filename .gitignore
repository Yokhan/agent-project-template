# Environment - NEVER commit these
.env
.env.local
.env.*.local

# Project-local Claude Code settings (not synced with template)
.claude/settings.local.json

# n8n local config (user-specific paths)
n8n/config.json

# Memory MCP local state
.memory/

# Session cache (runtime, regenerated)
.session-cache/

# MCP server dependencies (installed per-project)
mcp-servers/*/node_modules/
mcp-servers/*/dist/

# Active rules state (project-local, set by route-task.sh)
tasks/.active-rules
tasks/.mode
.engram/
.memcp/
.anima/
ia-memory/
tasks/.memory-fallback.md

# Beads local DB
.beads/beads.db

# IDE
.idea/
.vscode/*.json
!.vscode/extensions.json
*.swp
*.swo
*.suo
.DS_Store
Thumbs.db

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnp.*

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Go
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Rust
/target/
Cargo.lock.bak

# General build artifacts
dist/
out/
.cache/
*.log
coverage/
.coverage
htmlcov/

# Dashboard runtime (per-machine, regenerated)
tasks/chats/
tasks/.running-tasks.json
tasks/.current.md.bak

# Maintainer-local notes and audit logs
brain/01-daily/*
!brain/01-daily/.gitkeep
brain/03-knowledge/research/*
brain/03-knowledge/audits/*
tasks/audit/*

# Local bootstrap/smoke fixtures
codex-phase2-*-fixture/
codex-phase2-win-fixture/
codex-setup-smoke-*/
payload-fix-*/
template-leak-smoke-*/

# Temporary repro/debug artifacts
tmp-*
